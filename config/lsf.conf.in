#
# volclava main configuration file lsf.conf
# This file is designed as Bourne Shell rc file 
# and it is sourced by all volclava components.
#
LSF_SERVERDIR=@prefix@/sbin
LSF_BINDIR=@prefix@/bin

LSB_SHAREDIR=@prefix@/work
LSF_ENVDIR=@prefix@/etc

# Configuration directories
LSF_CONFDIR=@prefix@/etc
LSB_CONFDIR=@prefix@/etc

# Daemon log messages
LSF_LOGDIR=@prefix@/log
LSF_LOG_MASK=LOG_WARNING

# Daemons listening ports must not
# be in use by other programs.
LSF_LIM_PORT=6322
LSF_RES_PORT=6323
LSB_MBD_PORT=6324
LSB_SBD_PORT=6325
#
# Use eauth authentication.
LSF_AUTH=eauth

# Batch mail message handling
LSB_MAILTO=!U
#
LSF_PIM_SLEEPTIME_UPDATE=y

LSB_MAX_PACK_JOBS=300
LSB_PACK_SKIP_ERROR=N

# After setting, mbd will fork a child 
# process responsible for handling query requests
# must be enabled manually and port must not
# be in use by other programs.
# If not set or set to a non-numeric value or one outside 1-65535,
# the feature will not take effect.
LSB_QMBD_PORT=6326

#The following parameters take effect only after LSB_QMBD_PORT is set
LSB_QMBD_ALIVE_TIME=5         #maximum alive time (in seconds) for the qmbd subprocess,default is 5
LSB_QMBD_THREAD_NUM=10         #number of threads in qmbd's thread pool,default is 10
LSB_QMBD_MAX_TASK_NUM=2000     #capacity of qmbd's thread pool task queue,default is 2000
LSB_QMBD_SYNC_NEW_JOBS=y       #value: y = enable syncing new jobs; n = disable syncing new jobs,default is y
LSB_QMBD_SYNC_SHM_SIZE=1024    #size of shared memory for storing synchronized job information, default is 1024 unit: MB; only valid when LSB_QMBD_SYNC_NEW_JOBS=y
#