#
# volclava main configuration file lsf.conf
# This file is designed as Bourne Shell rc file 
# and it is sourced by all volclava components.
#
LSB_SHAREDIR=@prefix@/work
LSF_ENVDIR=@prefix@/etc

# Configuration directories
LSF_CONFDIR=@prefix@/etc
LSB_CONFDIR=@prefix@/etc

# Daemon log messages
LSF_LOGDIR=@prefix@/log
LSF_LOG_MASK=LOG_WARNING

# Daemons listening ports must not
# be in use by other programs.
LSF_LIM_PORT=6322
LSF_RES_PORT=6323
LSB_MBD_PORT=6324
LSB_SBD_PORT=6325

# After setting, mbd will fork a child 
# process responsible for handling query 
# requests (temporarily supports only 
# BATCH_JOB_INFO and BATCH_QUE_INFO)
# must be enabled manually and port must not
# be in use by other programs.
#LSB_QMBD_PORT=6326

#The following parameters take effect only after LSB_QMBD_PORT is set
#LSB_QMBD_SYNC_NEW_JOBS=y    #value: y = enable syncing new jobs; n = disable syncing new jobs,default is n
#LSB_QMBD_ALIVE_TIME=10      #alive time (in seconds) for the qmbd subprocess,default is 10
#LSB_QMBD_USE_THREAD_POOL=y  #Value: y = enable threadpool; n = disable threadpool,default is n

#The following parameters take effect only when LSB_QMBD_USE_THREAD_POOL is enabled
#LSB_QMBD_THREAD_NUM=16       #maximum number of threads in qmbd's thread pool,default is 8
#LSB_QMBD_MAX_TASK_NUM=10000 #capacity of qmbd's thread pool task queue,default is 10000
#

# Use eauth authentication.
LSF_AUTH=eauth

# Batch mail message handling
LSB_MAILTO=!U
#
LSF_PIM_SLEEPTIME_UPDATE=y

LSB_MAX_PACK_JOBS=300
LSB_PACK_SKIP_ERROR=N
